---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Organize thousands of photos by date, find duplicates, and manage locations with SnapAtlas." } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="description" content={description} />
	<meta name="generator" content={Astro.generator} />

	<!-- Open Graph -->
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:type" content="website" />

	<!-- Favicon -->
	<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

	<title>{title}</title>
	<link href={`${base}styles/global.css`} rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50">
	<header class="bg-white/85 shadow-sm sticky top-0 z-50 backdrop-blur-md border-b border-black/5">
	  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-16">
		  <div class="flex items-center">
			<a href={base} class="flex items-center space-x-3">
			  <svg class="w-8 h-8 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
			  </svg>
			  <span class="text-xl font-bold text-gray-900">SnapAtlas</span>
			</a>
		  </div>

		  <div class="hidden md:flex items-center space-x-8">
			<a href={base} class="text-gray-700 hover:text-teal-700 font-medium">Home</a>
			<a href={`${base}features`} class="text-gray-700 hover:text-teal-700 font-medium">Features</a>
			<a href={`${base}use-cases`} class="text-gray-700 hover:text-teal-700 font-medium">Use Cases</a>
			<a href={`${base}support`} class="text-gray-700 hover:text-teal-700 font-medium">Support</a>
			<a href={`${base}download`} class="btn-primary px-4 py-2 rounded-lg text-sm">Download</a>
		  </div>

		  <!-- Mobile menu button -->
		  <div class="md:hidden">
			<button type="button" aria-label="Toggle navigation menu" class="mobile-menu-button text-gray-700 hover:text-teal-700">
			  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
			  </svg>
			</button>
		  </div>
		</div>

		<!-- Mobile menu -->
		<div class="mobile-menu hidden md:hidden pb-4 space-y-2">
		  <a href={base} class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded">Home</a>
		  <a href={`${base}features`} class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded">Features</a>
		  <a href={`${base}use-cases`} class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded">Use Cases</a>
		  <a href={`${base}support`} class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded">Support</a>
		  <a href={`${base}download`} class="block px-4 py-2 bg-teal-700 text-white rounded text-center hover:bg-teal-800">Download</a>
		</div>
	  </nav>
	</header>

	<main class="flex-grow">
	  <slot />
	</main>

	<footer class="bg-gray-900 text-gray-300 mt-auto">
	  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
		  <div>
			<h3 class="text-white font-bold text-lg mb-4">SnapAtlas</h3>
			<p class="text-sm">Organize thousands of photos with intelligent date sorting, duplicate detection, and location management.</p>
		  </div>

		  <div>
			<h4 class="text-white font-semibold mb-4">Product</h4>
			<ul class="space-y-2 text-sm">
			  <li><a href={`${base}features`} class="hover:text-white">Features</a></li>
			  <li><a href={`${base}use-cases`} class="hover:text-white">Use Cases</a></li>
			  <li><a href={`${base}download`} class="hover:text-white">Download</a></li>
			</ul>
		  </div>

		  <div>
			<h4 class="text-white font-semibold mb-4">Support</h4>
			<ul class="space-y-2 text-sm">
			  <li><a href={`${base}support`} class="hover:text-white">Documentation</a></li>
			  <li><a href="https://github.com/XopherX/PhotoOrganizer" class="hover:text-white" target="_blank">GitHub</a></li>
			  <li><a href="mailto:support@northshoreapps.com" class="hover:text-white">Contact</a></li>
			</ul>
		  </div>

		  <div>
			<h4 class="text-white font-semibold mb-4">Legal</h4>
			<ul class="space-y-2 text-sm">
			  <li><a href={`${base}privacy`} class="hover:text-white">Privacy Policy</a></li>
			  <li><a href={`${base}terms`} class="hover:text-white">Terms of Service</a></li>
			</ul>
		  </div>
		</div>

		<div class="border-t border-gray-800 mt-8 pt-8 text-sm text-center">
		  <p>&copy; {new Date().getFullYear()} North Shore Apps. All rights reserved.</p>
		</div>
	  </div>
	</footer>

	<script>
	  // Mobile menu toggle
	  document.querySelector('.mobile-menu-button')?.addEventListener('click', () => {
		document.querySelector('.mobile-menu')?.classList.toggle('hidden');
	  });
	</script>
  </body>
</html>
