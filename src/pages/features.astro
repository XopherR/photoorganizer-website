---
import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { coreFeatures } from '../content/siteContent';

const icons = {
  organize: `<svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>`,
  duplicate: `<svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" /></svg>`,
  location: `<svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  batch: `<svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
  speed: `<svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  search: `<svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>`
};
---

<Layout
  title="SnapAtlas Features | Date, Location, and Duplicate Intelligence"
  description="Explore SnapAtlas features for organizing high-volume photo libraries with metadata-first workflows."
>
  <section class="container-custom pt-14 pb-8 md:pt-20">
    <p class="section-kicker">Feature walkthrough</p>
    <h1 class="text-4xl md:text-5xl font-bold mt-2">Organization features designed for archive-scale reality</h1>
    <p class="mt-5 text-lg text-slate-700 max-w-3xl">
      SnapAtlas focuses on high-impact cleanup and retrieval workflows instead of surface-level gallery browsing.
      Each capability is designed to reduce clutter and improve long-term discoverability.
    </p>
  </section>

  <section class="container-custom pb-16 space-y-8">
    {coreFeatures.map((feature, index) => (
      <FeatureCard
        title={feature.title}
        description={feature.description}
        icon={icons[feature.icon]}
        screenshot={feature.screenshot ? `${import.meta.env.BASE_URL}${feature.screenshot}` : undefined}
        reverse={index % 2 === 1}
      >
        <ul class="mt-4 space-y-2 text-slate-700">
          {feature.bullets.map((bullet) => (
            <li class="flex items-start gap-2">
              <span class="mt-1.5 h-2 w-2 rounded-full bg-cyan-600"></span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </FeatureCard>
    ))}
  </section>
</Layout>
