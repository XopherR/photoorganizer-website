---
interface Props {
  title: string;
  description: string;
  icon: string;
  screenshot?: string;
  reverse?: boolean;
}

const { title, description, icon, screenshot, reverse = false } = Astro.props;
---

<div class={`card flex flex-col ${reverse ? 'md:flex-row-reverse' : 'md:flex-row'} gap-6 items-center`}>
  <div class="flex-1 space-y-4">
	<div class="flex items-start space-x-3">
	  <div class="flex-shrink-0">
		<div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
		  <Fragment set:html={icon} />
		</div>
	  </div>
	  <div class="flex-1">
		<h3 class="text-2xl font-bold text-gray-900 mb-2">{title}</h3>
		<p class="text-gray-600 text-lg leading-relaxed">{description}</p>
	  </div>
	</div>
	<slot />
  </div>

  {screenshot && (
	<div class="flex-1">
	  <div class="rounded-lg overflow-hidden shadow-lg border border-gray-200">
		<img 
		  src={screenshot} 
		  alt={`${title} screenshot`}
		  class="w-full h-auto object-cover"
		  loading="lazy"
		/>
	  </div>
	</div>
  )}
</div>
